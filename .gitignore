# Git Ignore - Revisão de Literatura

# Dados Brutos (confidencial/grande)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json

# PDFs (podem ser copyright)
articles/pdf/*.pdf

# Outputs processados (regeneráveis)
data/processed/*.csv
data/processed/*.xlsx
data/processed/*.json

# Ficamentos auto-gerados (regeneráveis com IA)
analysis/fichamentos/*.md
!analysis/fichamentos/TEMPLATE-FICHAMENTO.md

# Validação em progresso
analysis/validacao/amostra_validacao.csv
analysis/validacao/matriz_validacao.xlsx
analysis/validacao/*.xlsx

# Síntese em progresso
analysis/synthesis/*.csv
analysis/synthesis/*.xlsx
analysis/synthesis/*.png

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Ambiente
.env
.env.local
.env.*.local

# Jupyter
.ipynb_checkpoints/
*.ipynb

# API Keys (NUNCA commitar!)
api_key*
*secret*
*.key

# Cache
*.cache
.cache/

# Temporary
*.tmp
temp/
temporary/

# OS
Thumbs.db
.DS_Store

# Relatórios confidenciais (opcionalmente)
# relatorios_internos/
# feedback_privado/
